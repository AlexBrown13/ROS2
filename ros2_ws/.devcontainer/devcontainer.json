 {
    "name": "ROS2 Humble",
    "image": "ros-humble-image:latest",
    "remoteUser": "vscode",
    "workspaceFolder": "/home/vscode/ros2_ws",
    "mounts": [
        "source=${localWorkspaceFolder}/ros2_ws,target=/home/vscode/ros2_ws,type=bind"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.analysis.extraPaths": [
                    "/opt/ros/humble/local/lib/python3.10/dist-packages",
                    "/opt/ros/humble/lib/python3.10/site-packages"
                ]
            },
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-vscode.cpptools",
                "ms-python.python",
                "twxs.cmake"
            ]
        }
    }
}